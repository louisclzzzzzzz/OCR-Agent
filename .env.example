# Clé API Mistral (https://console.mistral.ai/) — à configurer dans Vercel (Project Settings > Environment Variables)
MISTRAL_API_KEY=

# Optionnel : modèle OCR Mistral à utiliser (par défaut mistral-ocr-2512)
MISTRAL_OCR_MODEL=mistral-ocr-2512

# Optionnel : modèle Mistral pour l'extraction structurée (par défaut mistral-small-latest)
MISTRAL_MODEL=mistral-small-latest
